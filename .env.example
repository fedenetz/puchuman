# Analytics is disabled unless both values below are explicitly configured.
# Only use a public GA4 measurement ID here; never add a private credential.
VITE_ANALYTICS_ENABLED=false
VITE_GA_MEASUREMENT_ID=

# Optional public override for the client-visible GoFeels reservation URL.
# The current GoFeels URL/token is already visible in browser code and is not a
# private secret. Never place a privileged GoFeels API key in a VITE_* variable.
VITE_GOFEELS_BOOKING_URL=

# Canonical production origin used by the static-page generator. Netlify builds
# is required for every production build; there is no localhost fallback.
# Example only. Set SITE_URL=https://puchuman.cl in the Netlify environment.
SITE_URL=https://example.com

# Optional same-origin endpoint that accepts scrubbed JSON error envelopes.
# Keeping this same-origin means it remains allowed by the site's CSP.
VITE_ERROR_MONITORING_ENDPOINT=
VITE_APP_RELEASE=
